<section class="contact-page" data-section-id="{{ section.id }}">
  <div class="contact-page__card">
    {% if section.settings.heading != blank %}
      <h1 class="contact-page__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.show_form %}
      {% form 'contact', class: 'contact-page__form' %}
        {% if form.posted_successfully? %}
          <p class="contact-page__success">Thank you for your message. We'll get back to you soon.</p>
        {% endif %}
        {% if form.errors %}
          <div class="contact-page__errors">{{ form.errors | default_errors }}</div>
        {% endif %}
        <input type="text" name="contact[name]" placeholder="Name" required>
        <input type="email" name="contact[email]" placeholder="Email" required>
        <textarea name="contact[body]" placeholder="Message" rows="5" required></textarea>
        <button type="submit" class="btn btn--primary">SEND</button>
      {% endform %}
    {% endif %}

    <div class="contact-page__details">
      {% if section.settings.email != blank %}
        <a href="mailto:{{ section.settings.email }}" class="contact-page__detail">{{ section.settings.email }}</a>
      {% endif %}
      {% if section.settings.phone != blank %}
        <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-page__detail">{{ section.settings.phone }}</a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .contact-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height) - 100px);
    padding: var(--spacing-2xl) var(--spacing-lg);
  }
  .contact-page__card {
    border: 1px solid var(--color-border);
    padding: var(--spacing-xl);
    max-width: 500px;
    width: 100%;
  }
  .contact-page__heading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
  }
  .contact-page__form input,
  .contact-page__form textarea {
    margin-bottom: 1rem;
    border: none;
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }
  .contact-page__form .btn {
    width: 100%;
    margin-top: 0.5rem;
  }
  .contact-page__details {
    margin-top: var(--spacing-xl);
    text-align: right;
  }
  .contact-page__detail {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }
  .contact-page__success {
    color: green;
    margin-bottom: 1rem;
    font-size: var(--font-size-sm);
  }
  .contact-page__errors {
    color: red;
    margin-bottom: 1rem;
    font-size: var(--font-size-sm);
  }
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SAY HI - BOOK A MEETING - REQUEST A CLASS"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Show contact form",
      "default": true
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@example.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number"
    }
  ]
}
{% endschema %}
