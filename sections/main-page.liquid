<section class="generic-page page-width">
  <h1 class="generic-page__title">{{ page.title }}</h1>
  <div class="generic-page__content rte">
    {{ page.content }}
  </div>
</section>

<style>
  .generic-page {
    max-width: 800px;
    padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-2xl);
  }
  .generic-page__title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--spacing-lg);
  }
  .generic-page__content {
    font-size: var(--font-size-base);
    line-height: 1.8;
  }
  .generic-page__content h2, .generic-page__content h3 { margin: 1.5em 0 0.75em; }
  .generic-page__content p { margin-bottom: 1.25em; }
</style>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
