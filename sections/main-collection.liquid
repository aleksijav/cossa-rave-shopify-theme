<div class="collection-page" data-section-id="{{ section.id }}">
  <div class="collection-page__header page-width">
    {% if section.settings.show_title and collection.title != blank %}
      <h1 class="collection-page__title">{{ collection.title }}</h1>
    {% endif %}

    <div class="collection-page__toolbar">
      <div class="collection-page__filters">
        {% if section.settings.enable_filtering %}
          <details class="filter-dropdown">
            <summary class="filter-dropdown__trigger">
              Filter: <span>Availability</span>
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5"/></svg>
            </summary>
            <div class="filter-dropdown__content">
              {% for filter in collection.filters %}
                {% if filter.type == 'boolean' or filter.type == 'list' %}
                  {% for value in filter.values %}
                    <label class="filter-option">
                      <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %}>
                      {{ value.label }} ({{ value.count }})
                    </label>
                  {% endfor %}
                {% endif %}
              {% endfor %}
            </div>
          </details>
        {% endif %}
      </div>
      <div class="collection-page__sort-count">
        {% if section.settings.enable_sorting %}
          <div class="sort-dropdown">
            <label for="sort-by">Sort by:</label>
            <select id="sort-by" onchange="window.location.href = this.value">
              {% for option in collection.sort_options %}
                <option value="{{ collection.url }}?sort_by={{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
        <span class="collection-page__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</span>
      </div>
    </div>
  </div>

  <div class="collection-page__grid grid grid--3-col">
    {% for product in collection.products %}
      <a href="{{ product.url }}" class="product-card">
        <div class="product-card__image-wrapper">
          {% if product.featured_image != blank %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="product-card__image"
              loading="lazy"
              width="800"
              height="800"
            >
          {% endif %}
        </div>
        <div class="product-card__info">
          <span class="product-card__title">{{ product.title }}</span>
          <span class="product-card__price">{{ product.price | money }}</span>
        </div>
      </a>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="collection-page__pagination page-width">
      {{ paginate | default_pagination: next: '→', previous: '←' }}
    </div>
  {% endif %}
</div>

<style>
  .collection-page__header {
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
  }
  .collection-page__title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--spacing-md);
  }
  .collection-page__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding-bottom: var(--spacing-md);
  }
  .collection-page__sort-count {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .collection-page__count {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
  .sort-dropdown {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--font-size-sm);
  }
  .sort-dropdown label {
    font-weight: 500;
    white-space: nowrap;
  }
  .sort-dropdown select {
    border: none;
    padding: 0.25rem 0;
    font-size: var(--font-size-sm);
    cursor: pointer;
    width: auto;
  }

  .filter-dropdown {
    position: relative;
  }
  .filter-dropdown__trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--font-size-sm);
    cursor: pointer;
    list-style: none;
  }
  .filter-dropdown__trigger::-webkit-details-marker { display: none; }
  .filter-dropdown__content {
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid var(--color-border);
    padding: var(--spacing-sm);
    min-width: 200px;
    z-index: 10;
  }
  .filter-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0;
    font-size: var(--font-size-sm);
    cursor: pointer;
  }
  .filter-option input {
    width: auto;
  }

  .collection-page__grid {
    gap: 0;
  }

  .collection-page__pagination {
    padding: var(--spacing-xl) 0;
    text-align: center;
  }
  .collection-page__pagination a,
  .collection-page__pagination span {
    padding: 0.5rem 0.75rem;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .collection-page__grid { grid-template-columns: repeat(2, 1fr); }
    .collection-page__toolbar { flex-direction: column; align-items: flex-start; }
  }
</style>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    }
  ]
}
{% endschema %}
