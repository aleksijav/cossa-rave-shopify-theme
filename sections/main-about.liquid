<section class="about-page" data-section-id="{{ section.id }}">
  <div class="about-page__hero">
    <div class="about-page__image">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | default: 'About' }}"
          loading="eager"
        >
      {% else %}
        <div class="about-page__image-placeholder"></div>
      {% endif %}
    </div>
    <div class="about-page__content">
      {% if section.settings.heading != blank %}
        <h1 class="about-page__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% for block in section.blocks %}
        {% if block.type == 'accordion' %}
          <div class="accordion-item" {{ block.shopify_attributes }}>
            <button class="accordion-trigger" aria-expanded="false">
              <span>{{ block.settings.heading }}</span>
              <span class="icon">+</span>
            </button>
            <div class="accordion-content">
              <div class="accordion-content__inner">
                {{ block.settings.content }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if section.settings.show_trusted_by %}
    <div class="about-page__trusted">
      <h3 class="about-page__trusted-heading">{{ section.settings.trusted_heading | default: 'TRUSTED BY' }}</h3>
      <div class="about-page__logos">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="about-page__logo" {{ block.shopify_attributes }}>
              {% if block.settings.logo != blank %}
                <img
                  src="{{ block.settings.logo | image_url: width: 200 }}"
                  alt="{{ block.settings.logo.alt | default: 'Partner logo' }}"
                  loading="lazy"
                >
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

<style>
  .about-page__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - var(--header-height) - 100px);
  }
  .about-page__image {
    position: relative;
    overflow: hidden;
  }
  .about-page__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about-page__image-placeholder {
    width: 100%;
    height: 100%;
    background: #f0ede8;
  }
  .about-page__content {
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .about-page__heading {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .about-page__trusted {
    padding: var(--spacing-xl) var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }
  .about-page__trusted-heading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
  }
  .about-page__logos {
    display: flex;
    align-items: center;
    gap: var(--spacing-2xl);
    flex-wrap: wrap;
  }
  .about-page__logo img {
    max-height: 50px;
    width: auto;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: all var(--transition);
  }
  .about-page__logo img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .about-page__hero { grid-template-columns: 1fr; }
    .about-page__image { min-height: 50vh; }
  }
</style>

{% schema %}
{
  "name": "About Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "COMMUNITY FOCUSSED WELLNESS EXPERIENCES"
    },
    {
      "type": "checkbox",
      "id": "show_trusted_by",
      "label": "Show trusted by section",
      "default": true
    },
    {
      "type": "text",
      "id": "trusted_heading",
      "label": "Trusted by heading",
      "default": "TRUSTED BY"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Section title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Partner logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Page"
    }
  ]
}
{% endschema %}
