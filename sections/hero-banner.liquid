<section class="hero-banner" data-section-id="{{ section.id }}">
  {% if section.settings.image != blank %}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | default: section.settings.heading }}"
      class="hero-banner__image"
      loading="eager"
    >
  {% else %}
    <div class="hero-banner__placeholder"></div>
  {% endif %}

  <div class="hero-banner__overlay"></div>

  <div class="hero-banner__content">
    {% if section.settings.heading != blank %}
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    <div class="hero-banner__buttons">
      {% if section.settings.button_1_text != blank %}
        <a href="{{ section.settings.button_1_url }}" class="btn btn--filled-dark">
          {{ section.settings.button_1_text }}
        </a>
      {% endif %}
      {% if section.settings.button_2_text != blank %}
        <a href="{{ section.settings.button_2_url }}" class="btn btn--outline-white">
          {{ section.settings.button_2_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    height: calc(100vh - var(--header-height));
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-banner__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #3C2415 0%, #5a3a28 100%);
  }
  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background: var(--color-overlay);
  }
  .hero-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: var(--spacing-lg);
  }
  .hero-banner__heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-hero);
    font-weight: 700;
    font-style: italic;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 0.25em;
    line-height: 0.9;
  }
  .hero-banner__subheading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 400;
    margin-bottom: 2rem;
  }
  .hero-banner__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-banner { min-height: 70vh; }
    .hero-banner__buttons { flex-direction: column; align-items: center; }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RAVE"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SOCIAL WELLNESS EXPERIENCES"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 text",
      "default": "CLASSES"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Button 2 link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
