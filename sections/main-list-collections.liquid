<section class="collections-page page-width">
  <h1 class="collections-page__title">Collections</h1>
  <div class="grid grid--3-col collections-page__grid">
    {% for collection in collections %}
      {% unless collection.handle == 'all' %}
        <a href="{{ collection.url }}" class="collection-card">
          <div class="collection-card__image-wrapper">
            {% if collection.image %}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title }}" loading="lazy">
            {% elsif collection.products.first.featured_image %}
              <img src="{{ collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ collection.title }}" loading="lazy">
            {% endif %}
          </div>
          <h2 class="collection-card__title">{{ collection.title }}</h2>
        </a>
      {% endunless %}
    {% endfor %}
  </div>
</section>

<style>
  .collections-page { padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-2xl); }
  .collections-page__title {
    font-size: var(--font-size-2xl);
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .collections-page__grid { gap: var(--spacing-lg); }
  .collection-card { display: block; text-align: center; }
  .collection-card__image-wrapper {
    aspect-ratio: 1;
    overflow: hidden;
    margin-bottom: var(--spacing-sm);
    background: #f5f5f5;
  }
  .collection-card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .collection-card:hover img { transform: scale(1.03); }
  .collection-card__title {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>

{% schema %}
{
  "name": "Collection List",
  "settings": []
}
{% endschema %}
