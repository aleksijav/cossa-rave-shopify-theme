{% if section.settings.enable %}
<div class="newsletter-popup" id="newsletter-popup" role="dialog" aria-label="Newsletter signup" aria-hidden="true">
  <div class="newsletter-popup__overlay" data-close-popup></div>
  <div class="newsletter-popup__content">
    <button class="newsletter-popup__close" data-close-popup aria-label="Close">&times;</button>
    {% if section.settings.heading != blank %}
      <h2 class="newsletter-popup__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="newsletter-popup__text">{{ section.settings.text }}</p>
    {% endif %}
    {% form 'customer', class: 'newsletter-popup__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.placeholder | default: 'Email' }}"
        required
        class="newsletter-popup__input"
        autocomplete="email"
      >
      <button type="submit" class="btn btn--filled-dark newsletter-popup__submit">
        {{ section.settings.button_text | default: 'SUBMIT' }}
      </button>
    {% endform %}
    <button class="newsletter-popup__dismiss" data-close-popup>
      {{ section.settings.dismiss_text | default: 'No, thanks.' }}
    </button>
  </div>
</div>
{% endif %}

<style>
  .newsletter-popup {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .newsletter-popup.is-open { display: flex; }
  .newsletter-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    cursor: pointer;
  }
  .newsletter-popup__content {
    position: relative;
    background: #fff;
    padding: 3rem;
    max-width: 520px;
    width: 90%;
    text-align: left;
  }
  .newsletter-popup__close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.75rem;
    color: var(--color-text);
    line-height: 1;
    transition: opacity var(--transition);
  }
  .newsletter-popup__close:hover { opacity: 0.5; }
  .newsletter-popup__heading {
    font-size: var(--font-size-xl);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .newsletter-popup__text {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .newsletter-popup__input {
    border: none;
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
    margin-bottom: 1.25rem;
    font-size: var(--font-size-base);
  }
  .newsletter-popup__submit {
    width: 100%;
    margin-bottom: 1rem;
  }
  .newsletter-popup__dismiss {
    display: block;
    width: 100%;
    text-align: center;
    background: none;
    border: none;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: opacity var(--transition);
  }
  .newsletter-popup__dismiss:hover { opacity: 0.6; }
</style>

{% schema %}
{
  "name": "Newsletter Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEWSLETTER"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "Sign up to receive news, updates and offers and get 10% discount on your first order."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SUBMIT"
    },
    {
      "type": "text",
      "id": "dismiss_text",
      "label": "Dismiss text",
      "default": "No, thanks."
    },
    {
      "type": "range",
      "id": "delay",
      "label": "Delay (seconds)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
